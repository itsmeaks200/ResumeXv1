GROQ_API_KEY=your_groq_api_key_here

# Gemini TTS — get key from aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Voice options: Zephyr Puck Charon Kore Fenrir Leda Orus Aoede Callirrhoe Autonoe Despina ...
GEMINI_TTS_VOICE=Kore

# Groq TTS — used as a fallback if Gemini TTS fails. Valid voices: autumn diana hannah austin daniel troy
TTS_VOICE=hannah

PORT=5000

# MongoDB — local or Atlas connection string
MONGODB_URI=mongodb://localhost:27017/resumex

# JWT secret — any long random string
JWT_SECRET=change_this_to_a_long_random_secret

# Optional: GitHub personal access token
# Without token: public repos only, 60 req/hr rate limit (fine for interviews)
# With token: private repos accessible, 5000 req/hr
GITHUB_TOKEN=
